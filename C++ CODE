#include <iostream>
#include <stdexcept>

using namespace std;

int divide(int a, int b) {
    if (b == 0) {
        throw runtime_error("Bug detected: Division by zero!");
    }
    return a / b;
}

int main() {
    int x, y;

    cout << "Enter two numbers: ";
    cin >> x >> y;

    try {
        int result = divide(x, y);
        cout << "Result: " << result << endl;
    }
    catch (runtime_error& e) {
        cout << e.what() << endl;
    }

    return 0;
}