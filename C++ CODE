#include <iostream>
using namespace std;

int main() {
    int marks;

    cout << "Enter your marks (0-100): ";
    cin >> marks;

    if (marks >= 0 && marks <= 100) {
        if (marks >= 40) {
            cout << "Pass";
        } else {
            cout << "Fail";
        }
    } else {
        cout << "Invalid marks";
    }

    return 0;
}